<style>
  #mainContent[data-hidden="true"] {
    display: none;
  }

  #passwordPrompt {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 1.5rem;
    background: var(--global-bg-color, #fff);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  #passwordPrompt[data-visible="true"] {
    display: flex;
  }

  .pp-card {
    width: 100%;
    max-width: 400px;
    padding: 2.5rem 2.25rem;
    background: var(--global-card-bg-color, #fff);
    border: 1px solid var(--global-divider-color, rgba(0, 0, 0, 0.1));
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    text-align: center;
    animation: pp-fade-in 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pp-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .pp-card h2 {
    margin: 0 0 0.4rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--global-text-color, #333);
  }

  .pp-card > p {
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
    color: var(--global-text-color-light, #999);
  }

  .pp-input-wrap {
    position: relative;
    margin-bottom: 0.875rem;
  }

  .pp-input-wrap .pp-lock {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--global-text-color-light, #999);
    pointer-events: none;
  }

  #pwd {
    width: 100%;
    padding: 0.625rem 0.625rem 0.625rem 2.5rem;
    font-size: 0.95rem;
    border: 1px solid var(--global-divider-color, #ddd);
    border-radius: 8px;
    background: var(--global-bg-color, #fff);
    color: var(--global-text-color, #333);
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  #pwd:focus {
    border-color: var(--global-theme-color, #7b3ff2);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--global-theme-color, #7b3ff2) 15%, transparent);
  }

  #pwd::placeholder {
    color: var(--global-text-color-light, #aaa);
  }

  .pp-card button {
    width: 100%;
    padding: 0.625rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--global-hover-text-color, #fff);
    background: var(--global-theme-color, #7b3ff2);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .pp-card button:hover {
    opacity: 0.88;
  }

  .pp-card button:active {
    transform: scale(0.98);
  }

  #passwordError {
    color: var(--global-highlight-color, #e74c3c);
    margin-top: 0.625rem;
    font-size: 0.85rem;
    display: none;
  }

  #passwordError[data-visible="true"] {
    display: block;
    animation: pp-shake 0.4s;
  }

  @keyframes pp-fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pp-shake {
    0%, 100% { transform: translateX(0); }
    25%      { transform: translateX(-5px); }
    75%      { transform: translateX(5px); }
  }

  @media (max-width: 480px) {
    .pp-card { padding: 2rem 1.5rem; }
  }
</style>

<div id="passwordPrompt" data-password-protected="true" data-visible="false">
  <div class="pp-card">
    <div class="pp-icon">🔒</div>
    <h2>此页受密码保护</h2>
    <p>请输入密码以访问此页面</p>
    <div class="pp-input-wrap">
      <span class="pp-lock">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </span>
      <input type="password" id="pwd" placeholder="输入密码" autocomplete="off">
    </div>
    <button type="button" id="ppSubmit">进入</button>
    <div id="passwordError" data-visible="false">❌ 密码错误，请重试</div>
  </div>
</div>

<div id="mainContent" data-hidden="true">
